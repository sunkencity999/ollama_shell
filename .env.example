# Copy to `.env` (git-ignored) and adjust. All vars are optional; they override
# config.json / config.local.json. Double-underscore denotes nesting.

# Default model to chat with
# OSHELL_DEFAULT_MODEL=llama3.2:latest

# Backend selection: ollama | openai | mlx
# OSHELL_PROVIDER__NAME=ollama
# OSHELL_PROVIDER__HOST=http://localhost:11434
# OSHELL_PROVIDER__API_KEY=          # only for openai-compatible backends

# Generation
# OSHELL_TEMPERATURE=0.7

# Agent loop safety cap (tool-call rounds per turn)
# OSHELL_MAX_TOOL_ITERATIONS=8
